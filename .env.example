# ============================================================
#  ШАБЛОН НАСТРОЕК. Скопируй этот файл в .env и заполни значения.
#  (Файл .env в репозиторий не попадёт — он в .gitignore)
# ============================================================

# --- БЕЗОПАСНОСТЬ (обязательно) ---
# Длинная случайная строка для подписи ссылок (HMAC).
# Сгенерировать можно командой: npm run gen-secret
SECRET_KEY=

# --- TELEGRAM (рекомендуется) ---
# Токен бота от @BotFather и ID чата, куда слать уведомления.
# Если оставить пустыми — уведомления просто не будут отправляться (без ошибок).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- ПАРОЛЬ НА ФОРМУ (необязательно) ---
# Если задать — при создании КП форма потребует этот пароль.
# Оставь пустым, чтобы форма работала без пароля.
ADMIN_PASSWORD=

# --- КОМПАНИЯ (для шапки КП) ---
COMPANY_NAME=Моя компания
COMPANY_LOGO_TEXT=МК

# --- ВАЛЮТА ---
# Сколько тенге в одном рубле (фиксированный курс по умолчанию).
EXCHANGE_RATE_KZT_PER_RUB=5.5
# Пробовать брать живой курс с Нацбанка РК (true/false).
USE_LIVE_RATE=false
# Показывать ли рубли по умолчанию (true/false).
SHOW_RUB=true
